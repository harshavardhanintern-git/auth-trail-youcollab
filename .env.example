# ═══════════════════════════════════════════════════════════════════
# YouCollab — Environment Template (repo root)
# Copy to .env  (Backend also reads Backend/.env if you prefer that
# layout — Backend/.env wins when both exist.)
# ═══════════════════════════════════════════════════════════════════

# --- SUPABASE (DATABASE ONLY — Supabase Auth is not used) ---
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for `npm run db:migrate` and `npm run db:seed`
# Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- CLERK AUTHENTICATION (https://dashboard.clerk.com → API Keys) ---
# Enable: Email+Password (verify via email code), Google, password reset
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# --- FRONTEND (Vite reads Frontend/.env; same Clerk instance) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# --- APPLICATION ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:8080

# --- FILE UPLOADS ---
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# --- INSTAGRAM GRAPH API (optional) ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8080/instagram/callback
